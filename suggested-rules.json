{
  "html": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n<meta charset=\"UTF-8\">\n<meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\">\n<title>MOTION — Official Rules & Info</title>\n<link href=\"https://fonts.googleapis.com/css2?family=Bebas+Neue&family=Barlow+Condensed:wght@300;400;600;700;800&family=Share+Tech+Mono&display=swap\" rel=\"stylesheet\">\n<style>\n:root {\n  --bg:        #010306;\n  --bg2:       #03080f;\n  --surface:   #050e1a;\n  --card:      #071525;\n  --border:    #0c2240;\n  --border2:   #0f2d54;\n  --blue:      #1565ff;\n  --blue-l:    #4d8bff;\n  --blue-gl:   #a8c8ff;\n  --gold:      #f0c040;\n  --white:     #eaf2ff;\n  --text:      #b8d4f0;\n  --muted:     #3d6080;\n  --danger:    #ff3a5c;\n  --success:   #22d98a;\n}\n\n* { margin:0; padding:0; box-sizing:border-box; }\n\nhtml { scroll-behavior: smooth; }\n\nbody {\n  background: var(--bg);\n  color: var(--text);\n  font-family: 'Barlow Condensed', sans-serif;\n  font-weight: 400;\n  min-height: 100vh;\n  overflow-x: hidden;\n}\n\n/* ── BACKGROUND EFFECTS ──────────────── */\n.bg-grid {\n  position: fixed; inset: 0; z-index: 0; pointer-events: none;\n  background-image:\n    linear-gradient(rgba(21,101,255,0.04) 1px, transparent 1px),\n    linear-gradient(90deg, rgba(21,101,255,0.04) 1px, transparent 1px);\n  background-size: 48px 48px;\n}\n.bg-glow-1 {\n  position: fixed; top: -300px; left: 50%; transform: translateX(-50%);\n  width: 900px; height: 600px; z-index: 0; pointer-events: none;\n  background: radial-gradient(ellipse, rgba(21,101,255,0.12) 0%, transparent 70%);\n}\n.bg-glow-2 {\n  position: fixed; bottom: -200px; right: -200px;\n  width: 600px; height: 600px; z-index: 0; pointer-events: none;\n  background: radial-gradient(circle, rgba(21,101,255,0.07) 0%, transparent 70%);\n}\n\n/* ── NAV ─────────────────────────────── */\n.nav {\n  position: fixed; top: 0; left: 0; right: 0; z-index: 100;\n  display: flex; align-items: center; justify-content: space-between;\n  padding: 0 40px; height: 64px;\n  background: rgba(1,3,6,0.92);\n  border-bottom: 1px solid var(--border);\n  backdrop-filter: blur(12px);\n}\n.nav-logo {\n  font-family: 'Bebas Neue', sans-serif;\n  font-size: 32px; letter-spacing: 8px;\n  color: var(--white);\n  text-decoration: none;\n}\n.nav-logo span { color: var(--blue-l); }\n.nav-links { display: flex; gap: 0; }\n.nav-link {\n  font-family: 'Share Tech Mono', monospace;\n  font-size: 10px; letter-spacing: 2px; text-transform: uppercase;\n  color: var(--muted); padding: 0 16px; height: 64px;\n  display: flex; align-items: center; text-decoration: none;\n  border-bottom: 2px solid transparent;\n  transition: color .2s, border-color .2s;\n}\n.nav-link:hover { color: var(--blue-l); border-bottom-color: var(--blue); }\n.nav-discord {\n  font-family: 'Share Tech Mono', monospace;\n  font-size: 10px; letter-spacing: 2px;\n  color: var(--blue-l); border: 1px solid var(--blue);\n  padding: 8px 16px; text-decoration: none;\n  transition: all .2s; background: rgba(21,101,255,0.08);\n}\n.nav-discord:hover { background: var(--blue); color: var(--white); }\n\n/* ── HERO ────────────────────────────── */\n.hero {\n  position: relative; z-index: 10;\n  min-height: 100vh;\n  display: flex; flex-direction: column;\n  align-items: center; justify-content: center;\n  text-align: center;\n  padding: 100px 24px 60px;\n  overflow: hidden;\n}\n\n/* Animated scan line */\n.hero::after {\n  content: '';\n  position: absolute; left: 0; right: 0;\n  height: 1px;\n  background: linear-gradient(90deg, transparent, rgba(21,101,255,0.6), transparent);\n  animation: scan 4s ease-in-out infinite;\n  pointer-events: none;\n}\n@keyframes scan {\n  0%   { top: 10%; opacity: 0; }\n  10%  { opacity: 1; }\n  90%  { opacity: 1; }\n  100% { top: 90%; opacity: 0; }\n}\n\n.hero-eyebrow {\n  font-family: 'Share Tech Mono', monospace;\n  font-size: 11px; letter-spacing: 6px;\n  color: var(--blue-l); margin-bottom: 20px;\n  opacity: 0; animation: fadeUp .6s .2s forwards;\n}\n.hero-title {\n  font-family: 'Bebas Neue', sans-serif;\n  font-size: clamp(72px, 14vw, 160px);\n  letter-spacing: 12px; line-height: .9;\n  color: var(--white);\n  text-shadow: 0 0 80px rgba(21,101,255,0.4), 0 0 160px rgba(21,101,255,0.15);\n  opacity: 0; animation: fadeUp .6s .35s forwards;\n}\n.hero-title span {\n  color: transparent;\n  -webkit-text-stroke: 1px rgba(77,139,255,0.5);\n}\n.hero-sub {\n  font-size: 18px; font-weight: 300; letter-spacing: 2px;\n  color: var(--muted); margin-top: 16px; max-width: 500px;\n  opacity: 0; animation: fadeUp .6s .5s forwards;\n}\n\n.hero-badges {\n  display: flex; gap: 12px; margin-top: 32px; flex-wrap: wrap; justify-content: center;\n  opacity: 0; animation: fadeUp .6s .65s forwards;\n}\n.badge {\n  font-family: 'Share Tech Mono', monospace; font-size: 10px;\n  letter-spacing: 3px; padding: 8px 18px;\n  border: 1px solid var(--border2); color: var(--text);\n  background: rgba(21,101,255,0.06);\n}\n.badge.hot {\n  border-color: var(--blue); color: var(--blue-l);\n  background: rgba(21,101,255,0.12);\n  box-shadow: 0 0 20px rgba(21,101,255,0.15);\n}\n\n.hero-scroll {\n  position: absolute; bottom: 32px; left: 50%; transform: translateX(-50%);\n  font-family: 'Share Tech Mono', monospace; font-size: 9px;\n  letter-spacing: 3px; color: var(--muted);\n  display: flex; flex-direction: column; align-items: center; gap: 8px;\n  animation: bob 2s ease-in-out infinite;\n}\n.scroll-line { width: 1px; height: 40px; background: linear-gradient(180deg, var(--blue), transparent); }\n@keyframes bob { 0%,100%{transform:translateX(-50%) translateY(0)} 50%{transform:translateX(-50%) translateY(6px)} }\n@keyframes fadeUp { from{opacity:0;transform:translateY(16px)} to{opacity:1;transform:translateY(0)} }\n\n/* ── MAIN CONTENT ────────────────────── */\n.main { position: relative; z-index: 10; }\n\n/* ── SECTION ─────────────────────────── */\n.section {\n  padding: 80px 0;\n  border-top: 1px solid var(--border);\n}\n.section-inner {\n  max-width: 1000px; margin: 0 auto; padding: 0 40px;\n}\n\n.section-header { margin-bottom: 48px; }\n.section-tag {\n  font-family: 'Share Tech Mono', monospace; font-size: 10px;\n  letter-spacing: 4px; color: var(--blue-l); margin-bottom: 8px;\n}\n.section-title {\n  font-family: 'Bebas Neue', sans-serif;\n  font-size: 52px; letter-spacing: 4px; color: var(--white);\n  line-height: 1;\n}\n.section-title span { color: var(--blue-l); }\n.section-desc {\n  font-size: 15px; font-weight: 300; color: var(--muted);\n  margin-top: 8px; max-width: 600px; line-height: 1.6;\n}\n\n/* ── FORMAT CARDS ────────────────────── */\n.format-grid {\n  display: grid; grid-template-columns: repeat(3,1fr); gap: 2px;\n  margin-bottom: 2px;\n}\n.format-card {\n  background: var(--card); border: 1px solid var(--border);\n  padding: 28px 20px; text-align: center;\n  position: relative; overflow: hidden;\n  transition: border-color .2s, transform .2s;\n}\n.format-card::before {\n  content: '';\n  position: absolute; top: 0; left: 0; right: 0; height: 2px;\n  background: linear-gradient(90deg, transparent, var(--blue), transparent);\n  opacity: 0; transition: opacity .3s;\n}\n.format-card:hover { border-color: var(--blue); transform: translateY(-2px); }\n.format-card:hover::before { opacity: 1; }\n.format-icon { font-size: 32px; margin-bottom: 12px; }\n.format-name {\n  font-family: 'Bebas Neue', sans-serif; font-size: 28px;\n  letter-spacing: 3px; color: var(--white); margin-bottom: 4px;\n}\n.format-type {\n  font-family: 'Share Tech Mono', monospace; font-size: 9px;\n  letter-spacing: 2px; color: var(--blue-l); margin-bottom: 12px;\n}\n.format-detail { font-size: 13px; color: var(--muted); line-height: 1.6; }\n\n/* ── RULES ───────────────────────────── */\n.rules-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 2px; }\n\n.rule-card {\n  background: var(--card); border: 1px solid var(--border);\n  padding: 24px 28px; display: flex; gap: 20px;\n  transition: border-color .2s;\n}\n.rule-card:hover { border-color: var(--border2); }\n.rule-num {\n  font-family: 'Bebas Neue', sans-serif; font-size: 42px;\n  color: var(--blue); opacity: .35; line-height: 1;\n  flex-shrink: 0; width: 40px;\n}\n.rule-body {}\n.rule-title {\n  font-family: 'Barlow Condensed', sans-serif;\n  font-weight: 700; font-size: 16px; letter-spacing: 1px;\n  color: var(--white); margin-bottom: 6px;\n}\n.rule-text {\n  font-size: 14px; color: var(--muted); line-height: 1.7;\n}\n.rule-text strong { color: var(--text); }\n.rule-text .flag { color: var(--danger); font-weight: 600; }\n.rule-text .good { color: var(--success); font-weight: 600; }\n\n/* Rule category label */\n.rules-cat {\n  grid-column: 1 / -1;\n  font-family: 'Share Tech Mono', monospace; font-size: 10px;\n  letter-spacing: 4px; color: var(--blue-l);\n  padding: 20px 0 8px;\n  border-bottom: 1px solid var(--border);\n  margin-bottom: 2px;\n}\n\n/* ── PRIZES ──────────────────────────── */\n.prizes-wrap {\n  display: grid; grid-template-columns: repeat(2,1fr); gap: 2px;\n  margin-bottom: 24px;\n}\n.prize-card {\n  background: var(--card); border: 1px solid var(--border);\n  padding: 32px 24px; text-align: center; position: relative;\n  overflow: hidden;\n}\n.prize-card.first {\n  border-color: var(--gold);\n  background: linear-gradient(160deg, #1a1200, var(--card));\n  box-shadow: 0 0 60px rgba(240,192,64,0.12);\n}\n.prize-card.first::before {\n  content: '';\n  position: absolute; top: 0; left: 0; right: 0; height: 2px;\n  background: linear-gradient(90deg, transparent, var(--gold), transparent);\n}\n.prize-card.second::before {\n  content: '';\n  position: absolute; top: 0; left: 0; right: 0; height: 2px;\n  background: linear-gradient(90deg, transparent, #b0c4d8, transparent);\n}\n.prize-place {\n  font-family: 'Bebas Neue', sans-serif;\n  font-size: 52px; line-height: 1; margin-bottom: 4px;\n}\n.prize-card.first  .prize-place { color: var(--gold); text-shadow: 0 0 30px rgba(240,192,64,.4); }\n.prize-card.second .prize-place { color: #b0c4d8; }\n.prize-medal { font-size: 28px; margin-bottom: 12px; display: block; }\n.prize-name {\n  font-family: 'Share Tech Mono', monospace; font-size: 10px;\n  letter-spacing: 3px; color: var(--muted); margin-bottom: 16px;\n}\n.prize-reward {\n  font-family: 'Bebas Neue', sans-serif; font-size: 22px;\n  letter-spacing: 2px; color: var(--white); margin-bottom: 6px;\n}\n.prize-note { font-size: 12px; color: var(--muted); line-height: 1.5; }\n\n.prize-info {\n  background: var(--card); border: 1px solid var(--border);\n  border-left: 3px solid var(--blue);\n  padding: 16px 20px; margin-top: 2px;\n  font-size: 14px; color: var(--text); line-height: 1.7;\n}\n.prize-info strong { color: var(--blue-l); }\n\n/* ── STAFF ───────────────────────────── */\n.staff-grid { display: grid; grid-template-columns: repeat(3,1fr); gap: 2px; }\n.staff-card {\n  background: var(--card); border: 1px solid var(--border);\n  padding: 24px; display: flex; gap: 16px; align-items: flex-start;\n  transition: border-color .2s;\n}\n.staff-card:hover { border-color: var(--border2); }\n.staff-avatar {\n  width: 46px;\n  height: 46px;\n  border-radius: 0;\n  overflow: hidden;              /* allows image crop */\n  flex-shrink: 0;\n  border: 1px solid var(--border2);\n}\n\n/* Image inside avatar */\n.staff-avatar img {\n  width: 100%;\n  height: 100%;\n  object-fit: cover;             /* keeps image proportional */\n  display: block;\n}\n.staff-info {}\n.staff-role {\n  font-family: 'Share Tech Mono', monospace; font-size: 9px;\n  letter-spacing: 2px; color: var(--blue-l); margin-bottom: 3px;\n}\n.staff-name {\n  font-weight: 700; font-size: 16px; color: var(--white);\n  letter-spacing: .5px; margin-bottom: 2px;\n}\n.staff-discord { font-size: 12px; color: var(--muted); }\n.staff-placeholder {\n  font-style: italic; color: var(--border2); font-size: 13px;\n}\n\n/* ── SOCIALS ─────────────────────────── */\n.socials-grid { display: grid; grid-template-columns: repeat(4,1fr); gap: 2px; }\n.social-card {\n  background: var(--card); border: 1px solid var(--border);\n  padding: 28px 20px; text-align: center;\n  text-decoration: none; color: var(--text);\n  transition: border-color .2s, background .2s;\n  display: flex; flex-direction: column; align-items: center; gap: 12px;\n}\n.social-card:hover { border-color: var(--blue); background: rgba(21,101,255,0.06); }\n.social-icon { font-size: 32px; }\n.social-platform {\n  font-family: 'Bebas Neue', sans-serif;\n  font-size: 20px; letter-spacing: 3px; color: var(--white);\n}\n.social-handle {\n  font-family: 'Share Tech Mono', monospace; font-size: 11px;\n  color: var(--blue-l); letter-spacing: 1px;\n}\n.social-desc { font-size: 12px; color: var(--muted); }\n\n/* Discord special card */\n.discord-banner {\n  background: linear-gradient(135deg, #040d1a, #071e3d);\n  border: 1px solid var(--blue);\n  padding: 40px; text-align: center;\n  position: relative; overflow: hidden;\n  box-shadow: 0 0 60px rgba(21,101,255,0.1);\n}\n.discord-banner::before {\n  content: '';\n  position: absolute; top: 0; left: 0; right: 0; height: 2px;\n  background: linear-gradient(90deg, transparent, var(--blue-l), transparent);\n}\n.discord-banner::after {\n  content: '';\n  position: absolute; bottom: 0; left: 0; right: 0; height: 2px;\n  background: linear-gradient(90deg, transparent, var(--blue), transparent);\n}\n.discord-icon { font-size: 48px; margin-bottom: 12px; display: block; }\n.discord-title {\n  font-family: 'Bebas Neue', sans-serif; font-size: 40px;\n  letter-spacing: 5px; color: var(--white); margin-bottom: 8px;\n}\n.discord-sub {\n  font-size: 15px; font-weight: 300; color: var(--muted);\n  margin-bottom: 24px; max-width: 400px; margin-left: auto; margin-right: auto;\n}\n.discord-btn {\n  display: inline-block;\n  font-family: 'Bebas Neue', sans-serif; font-size: 20px; letter-spacing: 4px;\n  color: var(--white); background: var(--blue);\n  padding: 14px 40px; text-decoration: none;\n  transition: all .2s;\n  box-shadow: 0 0 40px rgba(21,101,255,0.4);\n}\n.discord-btn:hover {\n  background: var(--blue-l); box-shadow: 0 0 60px rgba(21,101,255,0.6);\n  transform: translateY(-2px);\n}\n\n/* ── FOOTER ──────────────────────────── */\n.footer {\n  position: relative; z-index: 10;\n  border-top: 1px solid var(--border);\n  padding: 32px 40px;\n  display: flex; align-items: center; justify-content: space-between;\n  max-width: 1000px; margin: 0 auto;\n}\n.footer-logo {\n  font-family: 'Bebas Neue', sans-serif;\n  font-size: 24px; letter-spacing: 6px; color: var(--muted);\n}\n.footer-logo span { color: var(--blue); }\n.footer-text {\n  font-family: 'Share Tech Mono', monospace; font-size: 10px;\n  letter-spacing: 2px; color: var(--border2); text-align: right;\n}\n\n/* ── DIVIDER ─────────────────────────── */\n.rule-divider {\n  height: 1px; background: var(--border); margin: 4px 0;\n}\n\n/* ── UTILITIES ───────────────────────── */\n.chip {\n  display: inline-block;\n  font-family: 'Share Tech Mono', monospace; font-size: 9px;\n  letter-spacing: 2px; padding: 3px 10px; border: 1px solid;\n  margin: 2px;\n}\n.chip-blue  { color: var(--blue-l);  border-color: var(--blue);    background: rgba(21,101,255,.08); }\n.chip-red   { color: var(--danger);  border-color: var(--danger);  background: rgba(255,58,92,.06); }\n.chip-green { color: var(--success); border-color: var(--success); background: rgba(34,217,138,.06); }\n.chip-gold  { color: var(--gold);    border-color: var(--gold);    background: rgba(240,192,64,.06); }\n\n/* ── RESPONSIVE ──────────────────────── */\n@media(max-width:768px){\n  .nav-links { display: none; }\n  .format-grid  { grid-template-columns: repeat(2,1fr); }\n  .rules-grid   { grid-template-columns: 1fr; }\n  .prizes-wrap  { grid-template-columns: 1fr; }\n  .staff-grid   { grid-template-columns: 1fr; }\n  .socials-grid { grid-template-columns: repeat(2,1fr); }\n  .section-inner { padding: 0 20px; }\n  .nav { padding: 0 20px; }\n  .hero-title { font-size: 64px; }\n}\n\n@media print {\n  .nav, .hero-scroll, .bg-grid, .bg-glow-1, .bg-glow-2 { display: none; }\n  .hero { min-height: auto; padding: 40px 24px; }\n}\n</style>\n</head>\n<body>\n\n<div class=\"bg-grid\"></div>\n<div class=\"bg-glow-1\"></div>\n<div class=\"bg-glow-2\"></div>\n\n<!-- NAV -->\n<nav class=\"nav\">\n  <a href=\"#\" class=\"nav-logo\">MOTI<span>ON</span></a>\n  <div class=\"nav-links\">\n    <a class=\"nav-link\" href=\"#formats\">Formats</a>\n    <a class=\"nav-link\" href=\"#rules\">Rules</a>\n    <a class=\"nav-link\" href=\"#prizes\">Prizes</a>\n    <a class=\"nav-link\" href=\"#staff\">Staff</a>\n    <a class=\"nav-link\" href=\"#socials\">Socials</a>\n  </div>\n  <a class=\"nav-discord\" href=\"https://discord.gg/Ynz7Xynd4Z\" target=\"_blank\">JOIN DISCORD →</a>\n</nav>\n\n<!-- HERO -->\n<section class=\"hero\">\n  <div class=\"hero-eyebrow\">// ROCKET LEAGUE ESPORTS COMMUNITY</div>\n  <div class=\"hero-title\">MOT<span>I</span>ON</div>\n  <div class=\"hero-sub\">Official Rules, Formats &amp; Info — Read before you compete.</div>\n  <div class=\"hero-badges\">\n    <div class=\"badge hot\"> SEASON 1 ACTIVE</div>\n    <div class=\"badge\">1V1 · 3V3 · 4V4</div>\n    <div class=\"badge\">ROCKET LEAGUE</div>\n    <div class=\"badge\">OPEN TO ALL RANKS</div>\n  </div>\n</section>\n\n<main class=\"main\"><section class=\"section\" id=\"formats\">\n    <div class=\"section-inner\">\n      <div class=\"section-header\">\n        <div class=\"section-tag\">// 01 — GAME MODES</div>\n        <div class=\"section-title\">FORMATS <span>&</span> MODES</div>\n        <div class=\"section-desc\">Motion runs three competitive formats. Each has its own bracket, rules, and prize pool. Check Discord for which formats are active in the current season.</div>\n      </div>\n\n      <div class=\"format-grid\"><div class=\"format-card\"><span class=\"format-icon\">⚡</span><div class=\"format-name\">2V2</div><div class=\"format-type\">DOUBLES</div><div class=\"format-detail\">High-speed doubles. BO3 early rounds, BO5 semis and finals. Teams of 2 + 1 registered sub.</div></div><div class=\"format-card\"><span class=\"format-icon\">🚀</span><div class=\"format-name\">3V3</div><div class=\"format-type\">STANDARD</div><div class=\"format-detail\">The flagship format. Full team coordination. BO3 → BO5 finals. Our most common tournament.</div></div><div class=\"format-card\"><span class=\"format-icon\">🔥</span><div class=\"format-name\">4V4</div><div class=\"format-type\">CHAOS</div><div class=\"format-detail\">High chaos, high fun. BO3 throughout. Teams of 4 — all must be registered. No mid-series subs.</div></div></div>\n\n      <div style=\"display:grid;grid-template-columns:1fr 1fr 1fr;gap:2px;margin-top:2px;\">\n        <div style=\"background:var(--card);border:1px solid var(--border);padding:20px 24px;\">\n          <div style=\"font-family:'Share Tech Mono',monospace;font-size:9px;letter-spacing:3px;color:var(--blue-l);margin-bottom:8px;\">SERIES FORMAT</div>\n          <div style=\"font-size:14px;color:var(--text);line-height:1.8;white-space:pre-line\">Round 1 / QF: BO3\nSemifinals: BO5\nGrand Finals: BO5</div>\n        </div>\n        <div style=\"background:var(--card);border:1px solid var(--border);padding:20px 24px;\">\n          <div style=\"font-family:'Share Tech Mono',monospace;font-size:9px;letter-spacing:3px;color:var(--blue-l);margin-bottom:8px;\">BRACKET TYPE</div>\n          <div style=\"font-size:14px;color:var(--text);line-height:1.8;white-space:pre-line\">Regular cups: Single Elim\nSeason finals: Double Elim\nWeekly cups: Single Elim\nCheck Discord for current event type.</div>\n        </div>\n        <div style=\"background:var(--card);border:1px solid var(--border);padding:20px 24px;\">\n          <div style=\"font-family:'Share Tech Mono',monospace;font-size:9px;letter-spacing:3px;color:var(--blue-l);margin-bottom:8px;\">SERVER SETTINGS</div>\n          <div style=\"font-size:14px;color:var(--text);line-height:1.8;white-space:pre-line\">Mutators: OFF\nRumble/Heatseeker: OFF\nServer region: Closest mutual\nLobby: Private / Password</div>\n        </div>\n      </div>\n    </div>\n  </section>\n\n  <section class=\"section\" id=\"rules\">\n    <div class=\"section-inner\">\n      <div class=\"section-header\">\n        <div class=\"section-tag\">// 02 — OFFICIAL RULESET</div>\n        <div class=\"section-title\">THE <span>RULES</span></div>\n        <div class=\"section-desc\">By registering for any Motion event you agree to every rule below. Admin decisions are final. These apply to all formats — 2v2, 3v3, and 4v4.</div>\n      </div>\n\n      <div class=\"rules-grid\">\n\n<div class=\"rules-cat\">REGISTRATION &amp; ELIGIBILITY</div><div class=\"rule-card\"><div class=\"rule-num\">01</div><div class=\"rule-body\"><div class=\"rule-title\">Account Verification</div><div class=\"rule-text\">All players must submit a <strong>Tracker.gg profile link</strong> during registration. Your account is verified by admins before the tournament. No link = no entry. No exceptions.</div></div></div><div class=\"rule-card\"><div class=\"rule-num\">02</div><div class=\"rule-body\"><div class=\"rule-title\">Main Accounts Only</div><div class=\"rule-text\"><span class=\"flag\">Smurfing is an immediate permanent ban.</span> You must compete on the exact account you registered. Alt accounts, boosted accounts, or accounts with misrepresented ranks are forbidden across all formats.</div></div></div><div class=\"rule-card\"><div class=\"rule-num\">03</div><div class=\"rule-body\"><div class=\"rule-title\">One Team Per Player</div><div class=\"rule-text\">Players may only be on <strong>one roster per tournament</strong>. Players found on multiple rosters are removed from both teams. Rosters lock at the registration deadline — no additions after that point.</div></div></div><div class=\"rule-card\"><div class=\"rule-num\">04</div><div class=\"rule-body\"><div class=\"rule-title\">Substitutes</div><div class=\"rule-text\">Teams may register <strong>1 sub per team</strong> during sign-up. Sub must be registered before the tournament — no day-of additions unless an admin approves in writing before the first match.</div></div></div>\n        <div class=\"rules-cat\">MATCH RULES</div><div class=\"rule-card\"><div class=\"rule-num\">05</div><div class=\"rule-body\"><div class=\"rule-title\">Lobby Creation</div><div class=\"rule-text\">The <strong>higher seeded team</strong> creates the private lobby. Password is shared via Discord DM to opponent captain only. Default: closest mutual region. Region disputes go to admin before match starts.</div></div></div><div class=\"rule-card\"><div class=\"rule-num\">06</div><div class=\"rule-body\"><div class=\"rule-title\">Ready-Up Window</div><div class=\"rule-text\">Teams have <strong>5 minutes</strong> after their match is called to be in the lobby. After 5 minutes, the opposing team may request a forfeit win. <span class=\"flag\">This is strictly enforced.</span> Be ready before your match is called.</div></div></div><div class=\"rule-card\"><div class=\"rule-num\">07</div><div class=\"rule-body\"><div class=\"rule-title\">Substitutions Mid-Series</div><div class=\"rule-text\">Subs may only swap <strong>between games</strong> in a series — never during a live game. For 4v4: all 4 players must be registered. No mid-series swaps in 4v4 under any circumstance.</div></div></div><div class=\"rule-card\"><div class=\"rule-num\">08</div><div class=\"rule-body\"><div class=\"rule-title\">Disconnections</div><div class=\"rule-text\">If a player disconnects <strong>before a goal is scored</strong>, both teams may agree to replay that game. If a goal was already scored, the game continues. Full lobby crashes are reviewed by admin only.</div></div></div>\n        <div class=\"rules-cat\">SCORE REPORTING &amp; DISPUTES</div><div class=\"rule-card\"><div class=\"rule-num\">09</div><div class=\"rule-body\"><div class=\"rule-title\">Reporting Results</div><div class=\"rule-text\">Winning team captain posts the final score + <strong>screenshot</strong> in <strong>#match-results</strong> within 5 minutes of the series ending. Losing captain confirms with ✅. Admin updates bracket.</div></div></div><div class=\"rule-card\"><div class=\"rule-num\">10</div><div class=\"rule-body\"><div class=\"rule-title\">Disputes</div><div class=\"rule-text\">Disputes must be raised in <strong>#disputes within 10 minutes</strong> of result. Evidence required from both teams. Admin reviews and rules — decision is <span class=\"flag\">final and immediate</span>. No further appeals.</div></div></div>\n        <div class=\"rules-cat\">CONDUCT</div><div class=\"rule-card\"><div class=\"rule-num\">11</div><div class=\"rule-body\"><div class=\"rule-title\">Sportsmanship</div><div class=\"rule-text\">Motion expects <span class=\"good\">GGs</span>. Toxic behavior, harassment, slurs, or targeted abuse toward any player, admin, or spectator — in-game, Discord, or publicly — results in <span class=\"flag\">immediate disqualification</span>.</div></div></div><div class=\"rule-card\"><div class=\"rule-num\">12</div><div class=\"rule-body\"><div class=\"rule-title\">Intentional Griefing</div><div class=\"rule-text\">Intentional self-destruction, AFK play, or any deliberate attempt to throw a match is treated as a conduct violation. Admins may review replay footage. Confirmed griefers are <span class=\"flag\">disqualified</span>.</div></div></div><div class=\"rule-card\"><div class=\"rule-num\">13</div><div class=\"rule-body\"><div class=\"rule-title\">Repeat Violations</div><div class=\"rule-text\">First major violation = disqualification from current event. Repeated violations = <span class=\"flag\">permanent server ban</span>. Motion is a community — protect it. Admins reserve the right to ban at any time for conduct deemed harmful to the community.</div></div></div><div class=\"rule-card\"><div class=\"rule-num\">14</div><div class=\"rule-body\"><div class=\"rule-title\">Admin Authority</div><div class=\"rule-text\">All admin decisions are <strong>final</strong>. Continued public complaints after a final ruling may result in disciplinary action. Admins are volunteers — respect them. Contact an admin privately for any serious concerns.</div></div></div>\n      </div>\n    </div>\n  </section>\n\n  <section class=\"section\" id=\"prizes\">\n    <div class=\"section-inner\">\n      <div class=\"section-header\">\n        <div class=\"section-tag\">// 03 — REWARDS</div>\n        <div class=\"section-title\">PRIZE <span>POOL</span></div>\n        <div class=\"section-desc\">Prize structure varies by event. Season finals will have a larger prize pool. Check #announcements for the exact prize breakdown for each tournament.</div>\n      </div>\n\n      <div class=\"prizes-wrap\">\n        <div class=\"prize-card first\">\n          <span class=\"prize-medal\">🥇</span>\n          <div class=\"prize-place\">1ST</div>\n          <div class=\"prize-name\">GRAND CHAMPION</div>\n          <div class=\"prize-reward\">TBD — Check #announcements</div>\n          <div class=\"prize-note\">Trophy role + Champion role + Hall of Fame Status + any cash/prize for that event</div>\n        </div>\n        <div class=\"prize-card second\">\n          <span class=\"prize-medal\">🥈</span>\n          <div class=\"prize-place\">2ND</div>\n          <div class=\"prize-name\">RUNNER-UP</div>\n          <div class=\"prize-reward\">TBD — Check #announcements</div>\n          <div class=\"prize-note\">Runner-up role</div>\n        </div>\n      </div>\n\n      <div class=\"prize-info\">\n        <strong>MVP Award:</strong> The player with the highest Strength Rating across all matches (tracked via our stats system) receives the Tournament MVP role and a special callout in the results post.\n      </div>\n\n      <div class=\"prize-info\" style=\"border-left-color:var(--gold);margin-top:2px;\">\n        <strong style=\"color:var(--gold)\">Prize Eligibility:</strong> All team members on the registered roster are prize-eligible. Day-of additions or unregistered substitutes are not eligible for prizes. Prizes distributed within 72 hours of tournament completion.\n      </div>\n    </div>\n  </section>\n\n  <section class=\"section\" id=\"staff\">\n    <div class=\"section-inner\">\n      <div class=\"section-header\">\n        <div class=\"section-tag\">// 04 — THE TEAM</div>\n        <div class=\"section-title\">STAFF <span>&</span> ADMINS</div>\n        <div class=\"section-desc\">Our admin team runs every event. For match disputes or questions, DM the relevant admin directly. Do not post disputes in general chat.</div>\n      </div>\n\n      <div class=\"staff-grid\">\n<div class=\"staff-card\"><div class=\"staff-avatar\"><img src=\"file:///C:/Users/Halep/MotionHub/hub-app/images/unclerico.png\" alt=\"\"></div><div class=\"staff-info\"><div class=\"staff-role\">HEAD ORGANIZER</div><div class=\"staff-name\">Uncle Rico</div><div class=\"staff-discord\">@Uncle Rico</div></div></div>\n        <div class=\"staff-card\"><div class=\"staff-avatar\"><img src=\"file:///C:/Users/Halep/MotionHub/hub-app/images/escanor.jpg\" alt=\"\"></div><div class=\"staff-info\"><div class=\"staff-role\">BRACKET ADMIN</div><div class=\"staff-name\">Escanor</div><div class=\"staff-discord\">@Escanor</div></div></div>\n        <div class=\"staff-card\" style=\"border-style:dashed;opacity:.5\"><div class=\"staff-avatar\"><div style=\"background:var(--border);color:var(--muted);width:100%;height:100%;display:flex;align-items:center;justify-content:center;font-size:20px;\">?</div></div><div class=\"staff-info\"><div class=\"staff-role\">DISPUTE ADMIN</div><div class=\"staff-name staff-placeholder\">Recruiting — DM Head Organizer</div><div class=\"staff-discord\"></div></div></div>\n        <div class=\"staff-card\" style=\"border-style:dashed;opacity:.5\"><div class=\"staff-avatar\"><div style=\"background:var(--border);color:var(--muted);width:100%;height:100%;display:flex;align-items:center;justify-content:center;font-size:20px;\">?</div></div><div class=\"staff-info\"><div class=\"staff-role\">COMMS / HYPE</div><div class=\"staff-name staff-placeholder\">Recruiting — DM Head Organizer</div><div class=\"staff-discord\"></div></div></div>\n        <div class=\"staff-card\" style=\"border-style:dashed;opacity:.5\"><div class=\"staff-avatar\"><div style=\"background:var(--border);color:var(--muted);width:100%;height:100%;display:flex;align-items:center;justify-content:center;font-size:20px;\">?</div></div><div class=\"staff-info\"><div class=\"staff-role\">STATS ADMIN</div><div class=\"staff-name staff-placeholder\">Recruiting — DM Head Organizer</div><div class=\"staff-discord\"></div></div></div>\n        <div class=\"staff-card\" style=\"border-style:dashed;opacity:.5\"><div class=\"staff-avatar\"><div style=\"background:var(--border);color:var(--muted);width:100%;height:100%;display:flex;align-items:center;justify-content:center;font-size:20px;\">?</div></div><div class=\"staff-info\"><div class=\"staff-role\">OPEN ROLE</div><div class=\"staff-name staff-placeholder\">Recruiting — DM Head Organizer</div><div class=\"staff-discord\"></div></div></div>\n      </div>\n\n      <div style=\"background:var(--card);border:1px solid var(--border);border-left:3px solid var(--blue-l);padding:16px 20px;margin-top:2px;font-size:14px;color:var(--text);line-height:1.7;\">\n        <strong style=\"color:var(--blue-l)\">Contact Protocol:</strong> For match disputes → DM Dispute Admin or post in #disputes. For bracket issues → DM Bracket Admin. For everything else → DM Head Organizer. Please do not spam multiple admins with the same issue.\n      </div>\n    </div>\n  </section></main>\n\n<!-- FOOTER -->\n<footer style=\"position:relative;z-index:10;border-top:1px solid var(--border);margin-top:0;\">\n  <div class=\"footer\">\n    <div>\n      <div class=\"footer-logo\">MOTI<span>ON</span></div>\n      <div style=\"font-family:'Share Tech Mono',monospace;font-size:9px;letter-spacing:2px;color:var(--border2);margin-top:4px;\">ROCKET LEAGUE ESPORTS</div>\n    </div>\n    <div class=\"footer-text\">\n      Rules subject to change — check Discord for updates.<br>\n      © Motion Rules · All rights reserved.\n    </div>\n  </div>\n</footer>\n\n<script>\n// Smooth active nav highlighting on scroll\nconst sections = document.querySelectorAll('section[id]');\nconst navLinks = document.querySelectorAll('.nav-link');\nwindow.addEventListener('scroll', () => {\n  let current = '';\n  sections.forEach(s => {\n    if (window.scrollY >= s.offsetTop - 100) current = s.id;\n  });\n  navLinks.forEach(l => {\n    l.style.color = l.getAttribute('href') === '#'+current ? 'var(--blue-l)' : '';\n    l.style.borderBottomColor = l.getAttribute('href') === '#'+current ? 'var(--blue)' : '';\n  });\n});\n</script>\n</body>\n</html>\n",
